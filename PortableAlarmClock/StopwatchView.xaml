<UserControl x:Class="PortableAlarmClock.StopwatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}">

    <UserControl.Resources>
        <!-- Circular Button Style -->
        <Style x:Key="CircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BgEllipse" Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgEllipse" Property="Fill" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgEllipse" Property="Fill" Value="{DynamicResource AccentPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Circle Button Style -->
        <Style x:Key="SecondaryCircleButtonStyle" TargetType="Button" BasedOn="{StaticResource CircleButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BgEllipse" Fill="{TemplateBinding Background}" 
                                     Stroke="{DynamicResource BorderBrush}" StrokeThickness="1"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgEllipse" Property="Fill" Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgEllipse" Property="Fill" Value="{DynamicResource ButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Lap Item Style -->
        <Style x:Key="LapItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,24,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Time Display -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
            <RowDefinition Height="*"/>      <!-- Laps List -->
        </Grid.RowDefinitions>

        <!-- 1. Header -->
        <TextBlock Text="&#x30B9;&#x30C8;&#x30C3;&#x30D7;&#x30A6;&#x30A9;&#x30C3;&#x30C1;" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <!-- 2. Elapsed Time Display -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,20,0,20">
            <TextBlock x:Name="ElapsedText" Text="00:00:00.00" 
                       FontSize="56" FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- 3. Control Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" 
                    Margin="0,8,0,24">
            <!-- Lap / Reset Button -->
            <Button x:Name="LapResetButton" Style="{StaticResource SecondaryCircleButtonStyle}"
                    Margin="0,0,24,0" Click="LapResetButton_Click" IsEnabled="False">
                <TextBlock x:Name="LapResetIcon" Text="&#xEA3A;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           ToolTip="Lap"/>
            </Button>

            <!-- Start/Stop Button -->
            <Button x:Name="StartStopButton" Style="{StaticResource CircleButtonStyle}" 
                    Width="72" Height="72" Click="StartStopButton_Click">
                <TextBlock x:Name="StartStopIcon" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="24"/>
            </Button>

            <!-- Placeholder for symmetry -->
            <Border Width="56" Height="56" Margin="24,0,0,0" Visibility="Hidden"/>
        </StackPanel>

        <!-- 4. Laps List -->
        <ListBox x:Name="LapsListBox" Grid.Row="3"
                 Background="Transparent"
                 BorderThickness="0"
                 ItemContainerStyle="{StaticResource LapItemStyle}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding LapNumber}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding LapTimeString}" FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding TotalTimeString}" FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
