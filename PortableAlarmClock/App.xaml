<Application x:Class="PortableAlarmClock.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PortableAlarmClock">
    <Application.Resources>
        <!-- Light/Dark Dynamic Brushes (Default values initialized in ThemeManager) -->
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#000000"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5F5F5F"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="ButtonPressedBrush" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="ToggleBackgroundBrush" Color="#8A8A8A"/>
        <SolidColorBrush x:Key="ToggleThumbBrush" Color="#000000"/>
        <SolidColorBrush x:Key="ListBoxBackgroundBrush" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="CardDisabledBrush" Color="#F8F8F8"/>
        <SolidColorBrush x:Key="TextDisabledBrush" Color="#AFAF00"/>

        <!-- Theme Constant Colors -->
        <SolidColorBrush x:Key="AccentBrush" Color="#005FB8"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1972C4"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#004D96"/>

        <!-- Global Font Settings -->
        <Style TargetType="Control">
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        </Style>
    </Application.Resources>
</Application>
